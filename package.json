{
  "name": "cordiss",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "dependencies": {
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.yukki.cordiss",
    "productName": "Cordiss Client",
    "files": [
      "main.js",
      "node_modules/**/*",
      "package.json",
      "icon.ico"
    ],
    "asar": true,
    "win": {
      "target": ["nsis"],
      "icon": "icon.ico"
    }
  }
}