{
  "name": "cordiss",
  "version": "1.0.4",
  "description": "Discord client for regional restrictions",
  "main": "main.js",
  "author": "RenYukki",
  "license": "GPL-3.0-or-later",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder build --win --portable",
    "publish": "electron-builder build --win --publish always",
    "dist": "electron-builder"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "electron-updater": "^6.1.4"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.6.4"
  },
  "build": {
    "appId": "com.renyukki.cordiss",
    "productName": "Cordiss",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "icon.ico"
    },
    "nsis": {
    "oneClick": true,
    "allowToChangeInstallationDirectory": false,
    "perMachine": false,
    "createDesktopShortcut": true,
    "runAfterFinish": true
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Renyukki",
        "repo": "Cordiss"
      }
    ]
  }
}